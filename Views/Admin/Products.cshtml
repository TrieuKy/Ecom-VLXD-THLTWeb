@model List<TrieuDoanKy_W2.Models.Product>
@{
    ViewData["Title"] = "Quản Lý Sản Phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0">Danh sách sản phẩm</h5>
        <a asp-controller="Product" asp-action="Add" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Thêm Mới</a>
    </div>
    <div class="card-body">
        <table class="table table-hover" id="productsTable">
            <thead class="table-dark">
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th>Giá bán</th>
                    <th>Tồn kho</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" width="50" height="50" style="object-fit:cover;border-radius:4px;" />
                            }
                            else
                            {
                                <div class="bg-light text-center" style="width:50px;height:50px;line-height:50px;"><i class="fas fa-box text-muted"></i></div>
                            }
                        </td>
                        <td class="fw-semibold">@p.Name</td>
                        <td>@(p.Category?.Name ?? "N/A")</td>
                        <td class="text-danger fw-bold">@p.Price.ToString("N0") ₫</td>
                        <td>
                            @if(p.Stock > 0){ <span class="badge bg-success">@p.Stock</span> }
                            else { <span class="badge bg-danger">Hết hàng</span> }
                        </td>
                        <td>
                            <a asp-controller="Product" asp-action="Update" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                            <a asp-controller="Product" asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                            <a asp-controller="Product" asp-action="Display" asp-route-id="@p.Id" class="btn btn-sm btn-outline-info" target="_blank"><i class="fas fa-eye"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#productsTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                }
            });
        });
    </script>
}
