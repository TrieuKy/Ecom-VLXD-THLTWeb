</div>

<!-- ===== DANH MỤC ===== -->
<div class="container-fluid px-4 mb-5">
    <div class="section-header d-flex justify-content-between align-items-end">
        <div>
            <div class="section-badge"><i class="fas fa-th-large me-2"></i>Danh mục</div>
            <h2 class="section-title">Mua Sắm Theo <span>Danh Mục</span></h2>
            <div class="section-line"></div>
        </div>
    </div>
    <div class="row g-3">
        @{
            var categories = ViewBag.Categories as List<TrieuDoanKy_W2.Models.Category>;
            var catIcons = new[] { "fas fa-bricks", "fas fa-paint-roller", "fas fa-industry", "fas fa-toilet", "fas fa-lightbulb", "fas fa-door-open" };
            var catColors = new[] { "#e65c00", "#198754", "#6c757d", "#0dcaf0", "#ffc107", "#dc3545" };
            var catBgs   = new[] { "#fff5f0", "#f0fff4", "#f5f5f5", "#f0f8ff", "#fffdf0", "#fff0f0" };
        }
        @if (categories != null && categories.Any())
        {
            for (int i = 0; i < categories.Count; i++)
            {
                var cat = categories[i];
                var icon = catIcons[i % catIcons.Length];
                var color = catColors[i % catColors.Length];
                var bg = catBgs[i % catBgs.Length];
                <div class="col-6 col-md-4 col-lg-2">
                    <a href="@Url.Action("Index", "Product", new { categoryId = cat.Id })" class="cat-card">
                        <div class="cat-icon-wrap" style="background:@bg; color:@color;">
                            <i class="@icon"></i>
                        </div>
                        <div class="cat-name">@cat.Name</div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<!-- ===== SẢN PHẨM NỔI BẬT ===== -->
<div class="container-fluid px-4 mb-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <div class="section-badge"><i class="fas fa-fire me-2"></i>Bán chạy</div>
            <h2 class="section-title">Sản Phẩm <span>Nổi Bật</span></h2>
            <div class="section-line"></div>
        </div>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary rounded-pill px-4 d-none d-md-inline-flex align-items-center gap-2">
            Xem tất cả <i class="fas fa-arrow-right"></i>
        </a>
    </div>

    @{
        var featured = ViewBag.FeaturedProducts as List<TrieuDoanKy_W2.Models.Product>;
    }
    @if (featured != null && featured.Any())
    {
        <div class="row g-3">
            @foreach (var p in featured)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card-home">
                        <!-- Image -->
                        <div class="product-img-wrap">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" />
                            }
                            else
                            {
                                <div class="product-img-placeholder">
                                    <i class="fas fa-box fa-3x" style="color:#ccc;"></i>
                                </div>
                            }
                            @if (p.Stock == 0)
                            {
                                <span class="badge-sold-out"><i class="fas fa-times me-1"></i>Hết hàng</span>
                            }
                            else if (p.Stock <= 5)
                            {
                                <span class="badge-hot"><i class="fas fa-fire me-1"></i>Sắp hết</span>
                            }
                            else
                            {
                                <span class="badge-new"><i class="fas fa-star me-1"></i>Nổi bật</span>
                            }
                            <button class="wishlist-btn" title="Yêu thích">
                                <i class="far fa-heart"></i>
                            </button>
                        </div>
                        <!-- Body -->
                        <div class="product-body">
                            @if (p.Category != null)
                            {
                                <div class="product-cat-tag">@p.Category.Name</div>
                            }
                            <div class="product-name-home" title="@p.Name">@p.Name</div>
                            <div class="product-price-home">
                                @p.Price.ToString("N0") ₫
                                <span class="product-unit-home">/@(p.Unit ?? "SP")</span>
                            </div>
                            @if (p.Stock > 0)
                            {
                                <div class="product-stock text-success">
                                    <i class="fas fa-check-circle me-1"></i>Còn @p.Stock @p.Unit
                                </div>
                            }
                            else
                            {
                                <div class="product-stock text-danger">
                                    <i class="fas fa-times-circle me-1"></i>Hết hàng
                                </div>
                            }
                            <!-- ACTION BUTTONS -->
                            <div class="product-actions">
                                @if (p.Stock > 0)
                                {
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <form asp-controller="Product" asp-action="AddToCart" method="post" class="flex-fill ajax-add-to-cart">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@p.Id" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <button type="submit" class="btn-cart-quick w-100">
                                                <i class="fas fa-cart-plus"></i>
                                                <span class="d-none d-sm-inline">Thêm giỏ</span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="btn-cart-quick flex-fill">
                                            <i class="fas fa-cart-plus"></i>
                                            <span class="d-none d-sm-inline">Mua ngay</span>
                                        </a>
                                    }
                                }
                                else
                                {
                                    <button class="btn-cart-quick flex-fill" disabled style="opacity:0.5; cursor:default;">
                                        <i class="fas fa-times"></i>Hết hàng
                                    </button>
                                }
                                <a asp-controller="Product" asp-action="Display" asp-route-id="@p.Id" class="btn-detail-quick" title="Xem chi tiết">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="text-center mt-4 d-md-none">
            <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary rounded-pill px-5">
                <i class="fas fa-arrow-right me-2"></i>Xem tất cả sản phẩm
            </a>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-box fa-4x text-muted opacity-25 mb-3 d-block"></i>
            <p class="text-muted">Chưa có sản phẩm. <a asp-controller="Admin" asp-action="Index">Thêm sản phẩm ngay</a></p>
        </div>
    }
</div>

<!-- ===== PROMO BANNER STRIP ===== -->
<div class="container-fluid px-4 mb-5">
    <div class="row g-3">
        <div class="col-md-6">
            <div class="promo-strip" style="background: linear-gradient(135deg, #e65c00, #cc4e00);">
                <img src="/images/cement.jpg" class="ps-bg" alt="" />
                <div class="ps-content">
                    <div style="color:rgba(255,255,255,0.8); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;">Ưu Đãi Hôm Nay</div>
                    <h3 style="color:white; font-weight:800; margin:0 0 12px;">Giảm 20% Xi Măng<br>& Vật Liệu Xây Thô</h3>
                    <a asp-controller="Product" asp-action="Index" asp-route-search="xi măng"
                       class="btn btn-warning btn-sm fw-bold rounded-pill px-4">Xem Ngay</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="promo-strip" style="background: linear-gradient(135deg, #0f3460, #16213e);">
                <img src="/images/steel.jpg" class="ps-bg" alt="" />
                <div class="ps-content">
                    <div style="color:rgba(255,255,255,0.8); font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;">Flash Sale</div>
                    <h3 style="color:white; font-weight:800; margin:0 0 12px;">Thép & Sắt Xây Dựng<br>Giá Sỉ Toàn Quốc</h3>
