@{
    ViewData["Title"] = "Trang Chủ - VLXD Shop";
}

<style>
    /* ===== HERO ===== */
    .hero-section {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        min-height: 520px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        margin: -16px -16px 0 -16px;
    }
    .hero-section::before {
        content: '';
        position: absolute; inset: 0;
        background: url('/images/hero-bg.jpg') center/cover no-repeat;
        opacity: 0.12;
    }
    .hero-section::after {
        content: '';
        position: absolute;
        top: -100px; right: -100px;
        width: 500px; height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(230,92,0,0.2) 0%, transparent 70%);
    }
    .hero-content { position: relative; z-index: 2; }
    .hero-badge {
        display: inline-block;
        background: rgba(249,212,35,0.15);
        border: 1px solid rgba(249,212,35,0.4);
        color: #f9d423;
        font-size: 13px;
        padding: 6px 16px;
        border-radius: 50px;
        margin-bottom: 20px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
    .hero-title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        color: white;
        line-height: 1.1;
        margin-bottom: 20px;
    }
    .hero-title .highlight { color: #f9d423; }
    .hero-desc { color: rgba(255,255,255,0.7); font-size: 1.1rem; margin-bottom: 32px; line-height: 1.7; }
    .hero-btn-primary {
        background: linear-gradient(135deg, #e65c00, #f9d423);
        color: white; border: none;
        padding: 14px 32px; border-radius: 12px;
        font-weight: 700; font-size: 16px;
        text-decoration: none; display: inline-flex; align-items: center; gap: 10px;
        transition: all 0.3s; box-shadow: 0 6px 20px rgba(230,92,0,0.4);
    }
    .hero-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(230,92,0,0.5); color: white; }
    .hero-btn-outline {
        background: rgba(255,255,255,0.1); color: white;
        border: 2px solid rgba(255,255,255,0.3);
        padding: 14px 28px; border-radius: 12px;
        font-weight: 600; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: all 0.3s; backdrop-filter: blur(10px);
    }
    .hero-btn-outline:hover { background: rgba(255,255,255,0.2); color: white; border-color: white; }
    .hero-stats { display: flex; gap: 40px; margin-top: 40px; }
    .hero-stat-num { font-size: 1.8rem; font-weight: 800; color: #f9d423; line-height: 1; }
    .hero-stat-label { font-size: 12px; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; }

    /* ===== TRUST BAR ===== */
    .trust-bar {
        background: white;
        border-bottom: 3px solid #f0f0f0;
        padding: 0;
    }
    .trust-item {
        display: flex; align-items: center; gap: 12px;
        padding: 18px 0;
        border-right: 1px solid #f0f0f0;
    }
    .trust-item:last-child { border-right: none; }
    .trust-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .trust-title { font-weight: 700; font-size: 14px; color: #1a1a2e; }
    .trust-subtitle { font-size: 12px; color: #888; }

    /* ===== SECTION HEADER ===== */
    .section-header { margin-bottom: 32px; }
    .section-badge { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #e65c00; margin-bottom: 8px; }
    .section-title { font-size: 1.8rem; font-weight: 800; color: #1a1a2e; margin: 0; }
    .section-title span { color: #e65c00; }
    .section-line { width: 50px; height: 4px; background: linear-gradient(135deg, #e65c00, #f9d423); border-radius: 2px; margin-top: 12px; }

    /* ===== CATEGORY CARDS ===== */
    .cat-card {
        background: white;
        border-radius: 16px;
        padding: 24px 16px;
        text-align: center;
        text-decoration: none;
        display: block;
        transition: all 0.3s ease;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 2px solid transparent;
        color: #333;
        height: 100%;
    }
    .cat-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.12);
        border-color: #e65c00;
        color: #e65c00;
    }
    .cat-icon-wrap {
        width: 64px; height: 64px;
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; margin: 0 auto 12px;
        transition: transform 0.3s;
    }
    .cat-card:hover .cat-icon-wrap { transform: scale(1.1) rotate(-5deg); }
    .cat-name { font-weight: 700; font-size: 13px; line-height: 1.3; }
    .cat-count { font-size: 11px; color: #aaa; margin-top: 4px; }

    /* ===== PRODUCT CARDS ===== */
    .product-card-home {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        transition: all 0.35s ease;
        height: 100%;
        display: flex; flex-direction: column;
        border: none;
    }
    .product-card-home:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
    }
    .product-img-wrap {
        height: 220px;
        position: relative;
        overflow: hidden;
        flex-shrink: 0;
    }
    .product-img-wrap img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }
    .product-card-home:hover .product-img-wrap img { transform: scale(1.08); }
    .product-img-placeholder {
        width: 100%; height: 100%;
        background: linear-gradient(135deg, #f0f0f0, #e0e0e0);
        display: flex; align-items: center; justify-content: center;
    }
    .badge-new {
        position: absolute; top: 12px; left: 12px;
        background: linear-gradient(135deg, #e65c00, #f9d423);
        color: white; font-size: 11px; font-weight: 700;
        padding: 4px 10px; border-radius: 20px;
    }
    .badge-hot {
        position: absolute; top: 12px; left: 12px;
        background: linear-gradient(135deg, #dc3545, #ff6b6b);
        color: white; font-size: 11px; font-weight: 700;
        padding: 4px 10px; border-radius: 20px;
    }
    .badge-sold-out {
        position: absolute; top: 12px; left: 12px;
        background: rgba(0,0,0,0.5); backdrop-filter: blur(5px);
        color: white; font-size: 11px; font-weight: 700;
        padding: 4px 10px; border-radius: 20px;
    }
    .wishlist-btn {
        position: absolute; top: 12px; right: 12px;
        width: 34px; height: 34px;
        background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);
        border-radius: 50%; border: none;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all 0.2s; color: #ccc;
        font-size: 14px;
    }
    .wishlist-btn:hover { color: #e65c00; transform: scale(1.1); }
    .product-body { padding: 16px; flex: 1; display: flex; flex-direction: column; }
    .product-cat-tag { font-size: 11px; color: #e65c00; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .product-name-home { font-weight: 700; font-size: 14px; color: #1a1a2e; line-height: 1.4; margin-bottom: 8px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 40px; }
    .product-price-home { font-size: 1.2rem; font-weight: 800; color: #e65c00; }
    .product-unit-home { font-size: 12px; color: #aaa; font-weight: 400; }
    .product-stock { font-size: 12px; margin: 6px 0 12px; }
    .product-actions { display: flex; gap: 8px; margin-top: auto; }
    .btn-cart-quick {
        flex: 1;
        background: linear-gradient(135deg, #e65c00, #f9d423);
        color: white; border: none;
        padding: 10px 8px; border-radius: 10px;
        font-weight: 700; font-size: 13px;
        cursor: pointer; transition: opacity 0.2s;
        text-decoration: none; text-align: center;
        display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .btn-cart-quick:hover { opacity: 0.9; color: white; }
    .btn-detail-quick {
        width: 42px; height: 42px;
        background: #f5f5f5; color: #555;
        border: none; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        text-decoration: none; transition: all 0.2s; flex-shrink: 0;
        font-size: 14px;
    }
    .btn-detail-quick:hover { background: #1a1a2e; color: white; }

    /* ===== BANNER STRIPS ===== */
    .promo-strip {
        border-radius: 20px; overflow: hidden;
        position: relative; height: 140px;
        display: flex; align-items: center; padding: 0 30px;
    }
    .promo-strip .ps-bg {
        position: absolute; inset: 0;
        width: 100%; height: 100%; object-fit: cover; opacity: 0.2;
    }
    .promo-strip .ps-content { position: relative; z-index: 1; }

    /* ===== TESTIMONIALS ===== */
    .testimonial-card {
        background: white; border-radius: 16px; padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .testimonial-avatar { width: 46px; height: 46px; border-radius: 50%; object-fit: cover; }
    .stars { color: #f9d423; font-size: 13px; }
</style>

<!-- ===== HERO ===== -->
<div class="hero-section px-4">
    <div class="container-fluid">
        <div class="row align-items-center py-5">
            <div class="col-lg-6 hero-content">
                <div class="hero-badge">
                    <i class="fas fa-hard-hat me-2"></i>Nhà phân phối VLXD uy tín số 1 TP.HCM
                </div>
                <h1 class="hero-title">
                    Vật Liệu Xây Dựng<br>
                    <span class="highlight">Chính Hãng – Giá Tốt</span>
                </h1>
                <p class="hero-desc">
                    Hơn 500 sản phẩm từ các thương hiệu hàng đầu. Giao hàng tận công trình,
                    tư vấn kỹ thuật miễn phí, đổi trả 30 ngày.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a asp-controller="Product" asp-action="Index" class="hero-btn-primary">
                        <i class="fas fa-boxes"></i>Khám Phá Sản Phẩm
                    </a>
                    <a asp-controller="Home" asp-action="Contact" class="hero-btn-outline">
                        <i class="fas fa-headset"></i>Tư Vấn Miễn Phí
                    </a>
                </div>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-num">500+</div>
                        <div class="hero-stat-label">Sản phẩm</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">10K+</div>
                        <div class="hero-stat-label">Khách hàng</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">15+</div>
                        <div class="hero-stat-label">Năm kinh nghiệm</div>
                    </div>
                    <div>
                        <div class="hero-stat-num">4.9★</div>
                        <div class="hero-stat-label">Đánh giá</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block text-center">
                <div style="position:relative; display:inline-block;">
                    <img src="/images/warehouse.jpg" alt="VLXD Shop Kho hàng"
                         style="width:100%; max-width:500px; border-radius:24px; box-shadow: 0 30px 80px rgba(0,0,0,0.4);" />
                    <!-- Floating card -->
                    <div style="position:absolute; bottom:-20px; left:-20px; background:white; border-radius:16px; padding:16px 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); display:flex; align-items:center; gap:12px; min-width:200px;">
                        <div style="width:44px;height:44px;background:linear-gradient(135deg,#198754,#20c997);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="fas fa-truck text-white"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;font-size:14px;color:#1a1a2e;">Giao hàng nhanh</div>
                            <div style="font-size:12px;color:#888;">Trong vòng 24 giờ</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== TRUST BAR ===== -->
