    <div class="container-fluid px-4">
        <div class="row">
            <div class="col-6 col-md-3">
                <div class="trust-item">
                    <div class="trust-icon" style="background:#fff5f0;">
                        <i class="fas fa-certificate" style="color:#e65c00;"></i>
                    </div>
                    <div>
                        <div class="trust-title">Hàng Chính Hãng</div>
                        <div class="trust-subtitle">100% có xuất xứ</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="trust-item">
                    <div class="trust-icon" style="background:#f0fff4;">
                        <i class="fas fa-truck" style="color:#198754;"></i>
                    </div>
                    <div>
                        <div class="trust-title">Freeship >10 triệu</div>
                        <div class="trust-subtitle">Nội thành TP.HCM</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="trust-item">
                    <div class="trust-icon" style="background:#f0f8ff;">
                        <i class="fas fa-headset" style="color:#0dcaf0;"></i>
                    </div>
                    <div>
                        <div class="trust-title">Hỗ Trợ 24/7</div>
                        <div class="trust-subtitle">Tư vấn kỹ thuật miễn phí</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="trust-item">
                    <div class="trust-icon" style="background:#fffdf0;">
                        <i class="fas fa-undo-alt" style="color:#ffc107;"></i>
                    </div>
                    <div>
                        <div class="trust-title">Đổi Trả 30 Ngày</div>
