@model TrieuDoanKy_W2.Models.ApplicationUser
@{
    ViewData["Title"] = "Thông Tin Cá Nhân";
    var orders = ViewBag.Orders as List<TrieuDoanKy_W2.Models.Order> ?? new List<TrieuDoanKy_W2.Models.Order>();
}

<div class="page-header mb-4">
    <h2><i class="fas fa-id-badge me-2" style="color:var(--primary);"></i>Quản Lý Tài Khoản</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Cột thông tin cá nhân -->
    <div class="col-lg-4">
        <div class="card shadow-sm border-0" style="border-radius:16px;">
            <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius:16px 16px 0 0;">
                <h5 class="mb-0 fw-bold"><i class="fas fa-user-circle me-2"></i>Hồ Sơ Của Bạn</h5>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width:80px;height:80px;font-size:32px;">
                        @(Model.FullName.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "U")
                    </div>
                    <h4 class="fw-bold mt-3 mb-1">@Model.FullName</h4>
                    <span class="badge bg-success">Thành viên</span>
                </div>

                <ul class="list-group list-group-flush mb-4">
                    <li class="list-group-item d-flex align-items-center px-0 py-3">
                        <i class="fas fa-envelope text-warning me-3" style="width:20px;"></i>
                        <div>
                            <div class="text-muted small">Email</div>
                            <div class="fw-semibold">@Model.Email</div>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center px-0 py-3">
                        <i class="fas fa-phone-alt text-warning me-3" style="width:20px;"></i>
                        <div>
                            <div class="text-muted small">Số điện thoại</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</div>
                        </div>
                    </li>
                    <li class="list-group-item d-flex align-items-center px-0 py-3">
                        <i class="fas fa-map-marker-alt text-warning me-3" style="width:20px;"></i>
                        <div>
                            <div class="text-muted small">Địa chỉ</div>
                            <div class="fw-semibold">@(string.IsNullOrEmpty(Model.Address) ? "Chưa cập nhật" : Model.Address)</div>
                        </div>
                    </li>
                </ul>

                <button type="button" class="btn btn-outline-primary w-100 rounded-pill" data-bs-toggle="modal" data-bs-target="#editProfileModal">
                    <i class="fas fa-edit me-2"></i>Cập nhật thông tin
                </button>
            </div>
        </div>
    </div>

    <!-- Cột lịch sử đơn hàng -->
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100" style="border-radius:16px;">
            <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #e65c00, #cc4e00); border-radius:16px 16px 0 0;">
                <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2"></i>Lịch Sử Đơn Hàng (@orders.Count)</h5>
            </div>
            <div class="card-body p-0">
                @if (orders.Count == 0)
                {
                    <div class="text-center py-5">
                        <div style="font-size:4rem; color:#e9ecef; margin-bottom:15px;">
                            <i class="fas fa-box-open"></i>
                        </div>
                        <h5 class="text-muted fw-bold">Bạn chưa có đơn hàng nào</h5>
                        <p class="text-muted mb-4">Khám phá các sản phẩm vật liệu xây dựng chất lượng ngay!</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-primary px-4 rounded-pill">
                            <i class="fas fa-shopping-bag me-2"></i>Mua sắm ngay
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Mã ĐH</th>
                                    <th>Ngày đặt</th>
                                    <th>Sản phẩm</th>
                                    <th class="text-end">Tổng tiền</th>
                                    <th class="text-center pe-4">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in orders)
                                {
                                    var itemsText = order.OrderDetails != null && order.OrderDetails.Any() 
                                        ? string.Join(", ", order.OrderDetails.Select(od => $"{od.Product?.Name} (x{od.Quantity})"))
                                        : "Không rõ";

                                    <tr>
                                        <td class="ps-4 fw-bold">#@order.Id</td>
                                        <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td style="max-width:250px;" class="text-truncate" title="@itemsText">
                                            @itemsText
                                        </td>
                                        <td class="text-end fw-bold text-danger">@order.TotalPrice.ToString("N0") ₫</td>
                                        <td class="text-center pe-4">
                                            @if (order.Status == "Chờ xác nhận")
                                            {
                                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">@order.Status</span>
                                            }
                                            else if (order.Status == "Đang giao")
                                            {
                                                <span class="badge bg-info text-dark px-3 py-2 rounded-pill">@order.Status</span>
                                            }
                                            else if (order.Status == "Hoàn thành")
                                            {
                                                <span class="badge bg-success px-3 py-2 rounded-pill">@order.Status</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-3 py-2 rounded-pill">@order.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal Edit Profile -->
<div class="modal fade" id="editProfileModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Cập Nhật Thông Tin</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Profile" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Họ và Tên</label>
                        <input type="text" name="FullName" value="@Model.FullName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Số điện thoại</label>
                        <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" name="Address" value="@Model.Address" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu Thay Đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>
