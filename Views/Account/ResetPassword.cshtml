@model TrieuDoanKy_W2.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white text-center py-4 border-0">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-unlock-alt me-2"></i>Đặt lại mật khẩu mới</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="ResetPassword" method="post">
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="Token" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control rounded-3" placeholder="Mật khẩu mới" />
                            <label asp-for="Password">Mật khẩu mới</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="ConfirmPassword" class="form-control rounded-3" placeholder="Xác nhận mật khẩu" />
                            <label asp-for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold mb-3 shadow-sm">
                            <i class="fas fa-save me-2"></i>Lưu mật khẩu mới
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
